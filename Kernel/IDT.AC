VD print_hex_digit(u8 n)
{
	C c[2];

	if(n < 10)
		c[0] = '0' + n;
	else
		c[0] = 'A' + (n - 10);

	c[1] = 0;

	print(c);
}

VD print_hex32(u32 n)
{
	print_hex_digit((n >> 28) & 0xF);
	print_hex_digit((n >> 24) & 0xF);
	print_hex_digit((n >> 20) & 0xF);
	print_hex_digit((n >> 16) & 0xF);
	print_hex_digit((n >> 12) & 0xF);
	print_hex_digit((n >> 8) & 0xF);
	print_hex_digit((n >> 4) & 0xF);
	print_hex_digit(n & 0xF);
}

VD print_dec(u32 n)
{
	C buf[16];
	C c[2];
	INT i;

	if(n == 0)
	{
		print("0");
		return;
	}

	i = 0;

	while(n > 0)
	{
		buf[i] = '0' + (n % 10);
		n = n / 10;
		i++;
	}

	while(i > 0)
	{
		i--;

		c[0] = buf[i];
		c[1] = 0;

		print(c);
	}
}

VD idt_set_gate(u8 num, u32 base, u16 sel, u8 flags)
{
	idt[num].base_low = base & 0xFFFF;
	idt[num].base_high = (base >> 16) & 0xFFFF;
	idt[num].sel = sel;
	idt[num].always0 = 0;
	idt[num].flags = flags;
}

VD print_exception_name(u32 INT_no)
{
	if(INT_no < 32)
		print(exceptions[INT_no]);
	else
		print("Unknown");
}

VD print_exception_info(u32 INT_no)
{
	if(INT_no < 32)
		print(exception_info[INT_no]);
	else
		print("Unknown CPU exception.");
}

VD print_caller_line(u32 addr, C *name)
{
	print_hex32(addr);
	print(":");
	print(name);
	print("\n");
}

VD exception_handler(ST Registers *r)
{
	cy = 80;
	color = 0x0F;
	defcolor = color;

	print(" Fault: ");

	if(r->INT_no < 32)
		print(exceptions[r->INT_no]);
	else
		print("Unknown");

	printadl(" Error Code", r->err_code);
	print("\n");

	beep(480);
        sleep(1000);
        nosound();
        sleep(1000);
        beep(480);
        sleep(1000);
        nosound();
        sleep(1000);
        beep(480);
        sleep(1000);
        nosound();
        sleep(1000);

	print("\n");
	print("          AneoEngine ERROR\n");
	print("Kernel halted due to CPU exception\n\n");

	print("\n\nException Report:\n");

	printadl("EIP", r->eip);
	printadl("EBP", r->ebp);

	print("\n");

	printadl("ESP", r->esp);
	printadl("EAX", r->eax);

        print("\n");

	printadl("EBX", r->ebx);
	printadl("ECX", r->ecx);

        print("\n");

	printadl("EDX", r->edx);
	printadl("ESI", r->esi);

        print("\n");

	printadl("EDI", r->edi);
	printadl("CS", r->cs);

        print("\n");

	printadl("DS", r->ds);
	printadl("ES", r->es);

        print("\n");

	printadl("FS", r->fs);
	printadl("GS", r->gs);

        print("\n");

	printadl("EFLAGS", r->eflags);
	print("\n\n");
	print("Press any key to continue.\n\n");

	u8 oldcy = cy;
        cy = 0;
	cx = 0;
        print("IDT Info                          \n");
        for(INT ia = 0; ia < 34; ia++) putc(196);
        print("\n");
        putc(179);
        printadl("Faulting Instruction", r->eip);
        putc(179);
        print("\n");
        putc(179);
        printadl("&exception_handler  ", (u32)&exception_handler);
        putc(179);
        print("\n");
        putc(179);
        printadl("&idt                ", (u32)&idt);
        putc(179);
        print("\n");
        putc(179);
        printadl("&idtp               ", (u32)&idtp);
        putc(179);
        print("\n");
        putc(179);
        printadl("Fault Addr          ", r->eip);
        putc(179);
        print("\n");
        putc(179);
        printadl("IDT Base            ", idtp.base);
        putc(179);
        print("\n");
        putc(179);
        printadl("IDT Limit           ", idtp.limit);
        putc(179);
        print("\n");
        putc(179);
        putc(192);
        for(INT i = 0; i < 31; i++) putc(196);
        putc(217);

        cy = oldcy;
        cx = 0;

	nosound();

	waitkey();

	triple_fault();
	//for(;;)
	//	__asm__ __volatile__("cli; hlt");
}

VD idt_init()
{
	print("Init IDT\n");
	INT i;

	idtp.limit = sizeof(ST IDTEntry) * 256 - 1;
	idtp.base = (u32)&idt;

	print("        Create IDT...");
	for(i = 0; i < 256; i++)
		idt_set_gate(i, 0, 0, 0);
