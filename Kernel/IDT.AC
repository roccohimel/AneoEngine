VD waitkey(VD)
{//wait till key is pressed; continue
        u8 sc;

        while (inb(0x64) & 1)
                inb(0x60);

        for (;;) {
                while (!(inb(0x64) & 1));

                sc = inb(0x60);

                if (!(sc & 0x80))
                        break;
        }
}


ST IDTEntry
{
	u16 base_low;
	u16 sel;
	u8 always0;
	u8 flags;
	u16 base_high;
} __attribute__((packed));

